{
	"$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",
	"assist": { "actions": { "source": { "organizeImports": "on" } } },
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineWidth": 80
	},
	"javascript": {
		"formatter": {
			"semicolons": "always",
			"quoteStyle": "double",
			"arrowParentheses": "asNeeded"
		}
	},
	"linter": {
		"enabled": false,
		"rules": {
			"recommended": true,
			"style": {
				"useConst": "off"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!discord-luau",
			"!**/dist",
			"!**/node_modules",
			"!**/.astro",
			"!**/src/content/docs"
		]
	}
}
