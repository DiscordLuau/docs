---
import Default from "@astrojs/starlight/components/Pagination.astro";
import syncedDirs from "../generated/synced-dirs.json";
import ContributorAvatars from "./ContributorAvatars.astro";

const entry = Astro.locals.starlightRoute.entry;
const id = entry?.id ?? "";
const excludedPages = ["", "404"];
const topDirectory = id.split("/")[0];
const isFromDiscordLuau = (syncedDirs as string[]).includes(topDirectory);

const contributorSources = [
	{ repo: "DiscordLuau/docs", path: `src/content/docs/${id}.mdx` },
	...(isFromDiscordLuau
		? [{ repo: "DiscordLuau/discord-luau", path: `docs/${id}.mdx` }]
		: []),
];
---

<div>
	{
		!excludedPages.includes(id) && (
			<>
				<div class="contributors">
					<ContributorAvatars sources={contributorSources} />
				</div>
				<br />
			</>
		)
	}
	<Default {...Astro.props}><slot /></Default>
</div>

<style>
	.contributors {
		display: flex;
		flex-direction: column;
		gap: 2.5rem;
		align-items: end;
	}
</style>
