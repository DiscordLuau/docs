---
const GITHUB_API_COMMITS_PER_PAGE = "100";
const GITHUB_API_ACCEPT_HEADER = "application/vnd.github+json";
const GITHUB_USER_AGENT = "discord-luau-docs/1.0";
const HTTP_STATUS_OK = 200;

interface CommitSource {
	repo: string;
	path: string;
}

interface GitHubAuthor {
	id: number;
	login: string;
}

interface GitHubCommit {
	author: GitHubAuthor | null;
}

interface Props {
	sources: CommitSource[];
}

const { sources } = Astro.props;

let warnedToken = false;
if (!import.meta.env.GITHUB_TOKEN && !warnedToken) {
	warnedToken = true;
	console.warn(
		"GITHUB_TOKEN not set — contributor avatars will not be fetched",
	);
}

async function fetchCommitsForSource(
	source: CommitSource,
): Promise<GitHubCommit[]> {
	const url = new URL(`https://api.github.com/repos/${source.repo}/commits`);
	url.searchParams.set("path", source.path);
	url.searchParams.set("per_page", GITHUB_API_COMMITS_PER_PAGE);

	const response = await fetch(url, {
		headers: {
			Authorization: `Bearer ${import.meta.env.GITHUB_TOKEN}`,
			Accept: GITHUB_API_ACCEPT_HEADER,
			"User-Agent": GITHUB_USER_AGENT,
		},
	});

	if (response.status !== HTTP_STATUS_OK) return [];
	return response.json();
}

function dedupeAuthors(commits: GitHubCommit[]): GitHubAuthor[] {
	const authorMap = new Map<number, GitHubAuthor>();
	for (const commit of commits) {
		if (commit.author) authorMap.set(commit.author.id, commit.author);
	}
	return Array.from(authorMap.values());
}

const allCommits = (
	await Promise.all(sources.map(fetchCommitsForSource))
).flat();
const authors = dedupeAuthors(allCommits);
---

{
	authors.length > 0 && (
		<div class="page-authors">
			<p>Page authors</p>
			<ul class="smol-avatar-list not-content">
				{authors.map(({ login, id }) => (
					<li>
						<a href={`https://github.com/${login}`}>
							<img
								alt={`Contributor ${login}`}
								width="64"
								height="64"
								src={`https://avatars.githubusercontent.com/u/${id}?size=64`}
							/>
						</a>
					</li>
				))}
			</ul>
		</div>
	)
}

<style define:vars={{ "avatar-count": authors.length }}>
	.page-authors {
		display: flex;
		flex-direction: column;
		gap: 0.5em;
		font-size: var(--sl-text-sm);
		font-weight: 600;
	}

	.smol-avatar-list {
		--avatar-size: 2rem;
		display: grid;
		grid-template-columns: repeat(var(--avatar-count), max(44px, calc(var(--avatar-size) / 1.15)));
		padding: 0.08em;
		font-size: var(--avatar-size);
		list-style: none;
	}

	@media (any-hover: hover) and (any-pointer: fine) {
		.smol-avatar-list {
			grid-template-columns: repeat(calc(var(--avatar-count) + 1), calc(var(--avatar-size) / 1.75));
		}
	}

	.smol-avatar-list li {
		width: var(--avatar-size);
		height: var(--avatar-size);
	}

	.smol-avatar-list li:hover ~ li a,
	.smol-avatar-list li:focus-within ~ li a {
		transform: translateX(33%);
	}

	.smol-avatar-list img,
	.smol-avatar-list a {
		display: block;
		border-radius: 50%;
	}

	.smol-avatar-list a {
		transition: transform 180ms ease-in-out;
	}

	.smol-avatar-list img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		background-color: #fff;
		box-shadow: 0 0 0 0.05em #fff, 0 0 0 0.08em rgba(0, 0, 0, 0.15);
	}

	.smol-avatar-list a:focus {
		outline: 2px solid transparent;
		box-shadow: 0 0 0 0.08em #29344b, 0 0 0 0.12em white;
	}
</style>
